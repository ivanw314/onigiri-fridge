# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Full public URL of this server (used for Square redirect_url and webhook URL)
BASE_URL=https://your-app.railway.app

# ── Database ──────────────────────────────────────────────────────────────────
# Injected automatically by Railway when Postgres is provisioned.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── HiveMQ Cloud ──────────────────────────────────────────────────────────────
HIVEMQ_HOST=your-cluster-id.s1.eu.hivemq.cloud
HIVEMQ_PORT=8883
HIVEMQ_USERNAME=your-device-username
HIVEMQ_PASSWORD=your-device-password

# ── Admin ─────────────────────────────────────────────────────────────────────
# Bearer token for the /api/admin/* endpoints. Generate with: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Device ────────────────────────────────────────────────────────────────────
# Shared HMAC secret between backend and ESP32.
# Lives only in ESP32 flash and this env var — never on the wire.
# For multiple devices: extend to DEVICE_SECRET_<device_id> and look up by device_id.
DEVICE_SECRET=change-me-to-a-long-random-string

# ── Square ────────────────────────────────────────────────────────────────────
# Sandbox:    https://connect.squareupsandbox.com
# Production: https://connect.squareup.com
SQUARE_API_BASE=https://connect.squareupsandbox.com

# From Square Developer Dashboard → your application → Credentials
SQUARE_ACCESS_TOKEN=EAAAl...your-sandbox-token
SQUARE_LOCATION_ID=your-location-id

# From Square Developer Dashboard → Webhooks → your endpoint
# The full URL Square posts to, e.g. https://your-app.railway.app/webhooks/square
SQUARE_WEBHOOK_URL=https://your-app.railway.app/webhooks/square
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

# Tax is pulled automatically from the sales-tax object already configured
# in Square's catalog (the same one the physical terminal uses), cached for
# a few hours. Only needed if the catalog has more than one enabled TAX
# object — set this to that tax's exact name to disambiguate.
SQUARE_TAX_NAME=

# ── Product ───────────────────────────────────────────────────────────────────
# The catalog now lives in the DB (see the admin panel's Items card) — these
# vars are only used to seed the first item on an empty database, and as a
# fallback price for orders placed before that migration.
ITEM_NAME=Onigiri
ITEM_PRICE_CENTS=300

# Optional — brand name shown on the /buy page header. Falls back to
# ITEM_NAME, then "Onigiri Fridge", if unset.
STORE_NAME=Onigiri Fridge
